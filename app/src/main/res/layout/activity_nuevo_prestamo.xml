<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="Nuevo préstamo"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_back"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Persona"
            android:textColor="@android:color/darker_gray"/>

        <Spinner
            android:id="@+id/spinnerPersona"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Objeto"
            android:textColor="@android:color/darker_gray"/>

        <EditText
            android:id="@+id/editObjeto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Descripción del objeto"
            android:inputType="text"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Categoría"
            android:textColor="@android:color/darker_gray"/>

        <Spinner
            android:id="@+id/spinnerCategoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Fecha préstamo"
            android:textColor="@android:color/darker_gray"/>

        <EditText
            android:id="@+id/editFechaPrestamo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="dd/mm/aaaa"
            android:inputType="date"
            android:focusable="false"
            android:clickable="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Fecha devolución prevista"
            android:textColor="@android:color/darker_gray"/>

        <EditText
            android:id="@+id/editFechaDevolucion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="dd/mm/aaaa (opcional)"
            android:inputType="date"
            android:focusable="false"
            android:clickable="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Foto del objeto"
            android:textColor="@android:color/darker_gray"/>

        <ImageView
            android:id="@+id/imageFotoPreview"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="4dp"
            android:background="@android:color/darker_gray"
            android:scaleType="centerCrop"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFoto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Hacer foto"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Firma digital del receptor"
            android:textColor="@android:color/darker_gray"/>

        <com.telopresto.app.view.FirmaView
            android:id="@+id/firmaView"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="4dp"
            android:background="@android:color/white"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLimpiarFirma"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Limpiar firma"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Notas"
            android:textColor="@android:color/darker_gray"/>

        <EditText
            android:id="@+id/editNotas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Observaciones adicionales"
            android:inputType="textMultiLine"
            android:lines="3"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Guardar préstamo"/>

    </LinearLayout>

</ScrollView>